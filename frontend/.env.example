# Frontend environment variables (copy to .env.local for local dev, or set in
# the Vercel Project Settings -> Environment Variables for production).
#
# Base URL of the deployed Python backend (Fly.io app). The app derives the
# WebSocket URL from this by swapping the scheme http->ws / https->wss
# (see frontend/src/app/page.tsx). Use the https:// URL in production so the
# WebSocket becomes wss:// — required for mic/WebRTC voice to work.
#
# Production example (replace with YOUR Fly app name):
NEXT_PUBLIC_BACKEND_URL=https://chart-fights-backend.fly.dev
#
# Local dev example (backend run with `uvicorn app.main:app` listens on 8001):
# NEXT_PUBLIC_BACKEND_URL=http://localhost:8001
